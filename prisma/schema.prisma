datasource db {
  provider = "mongodb"
}

generator client {
  provider = "prisma-client-js"
}

model Room {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  roomId     String   @unique
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  canvasData Json
}